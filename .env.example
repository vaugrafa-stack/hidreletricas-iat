# Copie este arquivo para .env e preencha os valores reais
# NUNCA commite o arquivo .env

# Caminho local do Excel sincronizado pelo Google Drive for Desktop
EXCEL_LOCAL_PATH=C:/Users/seu_usuario/Google Drive/Central_de_Processos_HIDRELETRICAS_COM_MACRO e Links.xlsm

# ID do arquivo no Google Drive (para verificação de data de modificação)
GOOGLE_DRIVE_FILE_ID=

# ArcGIS — usar usuário/senha OU token (não ambos)
ARCGIS_PORTAL_URL=https://www.arcgis.com
ARCGIS_USERNAME=
ARCGIS_PASSWORD=
ARCGIS_TOKEN=
ARCGIS_FEATURE_LAYER_ID=
ARCGIS_FOLDER=Hidreletricas_IAT

# Nível de log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ── Notificações por e-mail (módulo de Fiscalização) ──────────────────────────
# Sem estas variáveis, o dashboard ainda gera a prévia e o arquivo .eml — só o
# envio automático (com confirmação de leitura) fica indisponível.
IAT_SMTP_HOST=
IAT_SMTP_PORT=587
IAT_SMTP_USER=
IAT_SMTP_PASS=
IAT_SMTP_FROM=licenciamento@iat.pr.gov.br
IAT_SMTP_TLS=1
# Para onde voltam as confirmações de leitura (padrão = remetente):
IAT_SMTP_CONFIRM_TO=
# (opcional) pixel de rastreio de leitura, se hospedar um endpoint próprio:
# IAT_PIXEL_BASE=https://seu-endpoint/pixel

# ── Login do painel ───────────────────────────────────────────────────────────
# Em PRODUÇÃO, defina o hash da senha aqui (ou em Secrets do Streamlit Cloud) para
# que a senha real NÃO fique no repositório. Padrão no código = sha256("RAFAIAT").
# Gere com: python -c "import hashlib;print(hashlib.sha256('NOVA'.encode()).hexdigest())"
IAT_AUTH_USER=DILIO
IAT_AUTH_HASH=

# ── Acesso interno (edição) — hash SHA-256 da senha interna ───────────────────
# Padrão no código = sha256("FISCAL2026"). Gere outro como acima.
IAT_INTERNO_HASH=
